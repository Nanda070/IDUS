# Copy this file to .env and fill in real values. .env is gitignored.

# From https://my.telegram.org -> API development tools (your own account, for
# the userbot that sends messages/calls as you).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# From @BotFather on Telegram (the IDUS remote-access bot, Stage 11).
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (get it from @userinfobot) - the bot only
# responds to this ID, so strangers can't talk to your home assistant.
TELEGRAM_OWNER_ID=
